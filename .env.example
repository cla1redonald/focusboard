# ============================================
# FOCUSBOARD ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local for local development
# Set these in Vercel for production deployment

# ============================================
# CLIENT-SIDE (Required for cloud sync)
# ============================================
# These are exposed to the browser (VITE_ prefix)
# Get from Supabase Dashboard > Settings > API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# ============================================
# SERVER-SIDE (Required for webhook API)
# ============================================
# Set these in Vercel environment variables
# These are NOT exposed to the browser

# Same URL as above (without VITE_ prefix for server-side)
SUPABASE_URL=https://your-project.supabase.co

# Service role key - KEEP SECRET, bypasses RLS
# Get from Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# Your Supabase user UUID
# Find in Supabase Dashboard > Authentication > Users
# Or run in browser console: supabase.auth.getUser().then(({data}) => console.log(data.user.id))
FOCUSBOARD_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Shared secret for webhook authentication
# Generate with: openssl rand -hex 32
# Used in POST requests to /api/webhook/add-card
WEBHOOK_SECRET=your-random-secret-here

# ============================================
# OPTIONAL: Slack Integration
# ============================================
# Only needed if setting up Slack slash commands

# Get from Slack App > Basic Information > Signing Secret
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Get from Slack App > OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# ============================================
# OPTIONAL: Unsplash Integration
# ============================================
# Enable per-card background images from Unsplash

# Get free API key from https://unsplash.com/developers
# 1. Create a free account
# 2. Create a new application
# 3. Copy the Access Key (not Secret Key)
VITE_UNSPLASH_ACCESS_KEY=your-unsplash-access-key
