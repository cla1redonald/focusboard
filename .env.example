# ============================================
# FOCUSBOARD ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local for local development
# Set these in Vercel for production deployment

# ============================================
# CLIENT-SIDE (Required for cloud sync)
# ============================================
# These are exposed to the browser (VITE_ prefix)
# Get from Supabase Dashboard > Settings > API

# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
VITE_SUPABASE_URL=${VITE_SUPABASE_URL}
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
VITE_SUPABASE_ANON_KEY=${VITE_SUPABASE_ANON_KEY}

# ============================================
# SERVER-SIDE (Required for webhook API)
# ============================================
# Set these in Vercel environment variables
# These are NOT exposed to the browser

# Same URL as above (without VITE_ prefix for server-side)
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
SUPABASE_URL=${SUPABASE_URL}

# Service role key - KEEP SECRET, bypasses RLS
# Get from Supabase Dashboard > Settings > API > service_role key
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
SUPABASE_SERVICE_ROLE_KEY=${SUPABASE_SERVICE_ROLE_KEY}

# Your Supabase user UUID
# Find in Supabase Dashboard > Authentication > Users
# Or run in browser console: supabase.auth.getUser().then(({data}) => console.log(data.user.id))
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
FOCUSBOARD_USER_ID=${FOCUSBOARD_USER_ID}

# Shared secret for webhook authentication
# Generate with: openssl rand -hex 32
# Used in POST requests to /api/webhook/add-card
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
WEBHOOK_SECRET=${WEBHOOK_SECRET}

# ============================================
# OPTIONAL: Slack Integration
# ============================================
# Only needed if setting up Slack slash commands

# Get from Slack App > Basic Information > Signing Secret
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
SLACK_SIGNING_SECRET=${SLACK_SIGNING_SECRET}

# Get from Slack App > OAuth & Permissions > Bot User OAuth Token
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
SLACK_BOT_TOKEN=${SLACK_BOT_TOKEN}

# ============================================
# OPTIONAL: Unsplash Integration
# ============================================
# Enable per-card background images from Unsplash

# Get free API key from https://unsplash.com/developers
# 1. Create a free account
# 2. Create a new application
# 3. Copy the Access Key (not Secret Key)
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
VITE_UNSPLASH_ACCESS_KEY=${VITE_UNSPLASH_ACCESS_KEY}

# ============================================
# OPTIONAL: Notion Calendar Integration
# ============================================
# Show Google Calendar events (synced via Notion) in Weekly Plan view

# Get from https://www.notion.so/my-integrations
# 1. Create a new integration
# 2. Copy the Internal Integration Token
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
NOTION_API_KEY=${NOTION_API_KEY}

# The database ID of your Notion Calendar database
# Get from the database URL: notion.so/{workspace}/{database_id}?v=...
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
NOTION_CALENDAR_DATABASE_ID=${NOTION_CALENDAR_DATABASE_ID}

# ============================================
# OPTIONAL: AI Features
# ============================================
# Enable AI-powered suggestions and planning

# Get from https://console.anthropic.com/
# Add to your shell profile (~/.zshrc, ~/.bashrc, ~/.bash_profile etc)
# or use a secrets manager (Doppler, 1Password CLI)
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}

# ============================================
# OPTIONAL: File Attachments
# ============================================
# File attachments use Supabase Storage (no additional env vars needed)
# But you MUST run the SQL setup to create the storage bucket:
#
# 1. Go to Supabase Dashboard > SQL Editor
# 2. Run the SQL from: supabase/storage-bucket.sql
#
# This creates:
# - A private storage bucket named 'card-attachments'
# - RLS policies for user isolation (each user can only access their own files)
#
# File limits:
# - Max 10MB per file
# - Supported types: images, PDFs, Office docs, text, CSV, ZIP
