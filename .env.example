# Supabase Configuration (Optional)
# Cloud sync is disabled if these are not set.
# Get these values from your Supabase project settings.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Slack Integration (for API routes)
# These are only needed for the Slack integration.
# Add these to your Vercel environment variables.

# Same as VITE_SUPABASE_URL but for server-side
SUPABASE_URL=https://your-project.supabase.co

# Service role key (NOT the anon key) - find in Supabase Settings > API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Get from Slack App > Basic Information > Signing Secret
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Get from Slack App > OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Your Supabase user ID - find in Supabase Auth > Users
FOCUSBOARD_USER_ID=your-user-uuid-here
