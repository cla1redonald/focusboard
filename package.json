    "@vercel/speed-insights": "^1.3.1",
    "framer-motion": "^12.23.26",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.562.0",
    "nanoid": "^5.1.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
